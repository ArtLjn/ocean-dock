#!/bin/bash
# commit-msg: Conventional Commits 格式校验（仅警告不阻断）

COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
FIRST_LINE=$(echo "$COMMIT_MSG" | head -1)

YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

VALID_TYPES="^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\(.+\))?: .+"

if echo "$FIRST_LINE" | grep -qE "$VALID_TYPES"; then
    echo -e "${GREEN}[commit-msg] 提交格式正确${NC}"
else
    echo -e "${YELLOW}[commit-msg] WARNING: 提交信息不符合 Conventional Commits 格式${NC}"
    echo -e "${YELLOW}  期望格式: type(scope): description${NC}"
    echo -e "${YELLOW}  例如: feat(api): 添加用户认证接口${NC}"
    echo -e "${YELLOW}  类型: feat/fix/docs/style/refactor/test/chore/perf/ci/build/revert${NC}"
    echo -e "${YELLOW}  当前: $FIRST_LINE${NC}"
fi

TITLE_LEN=${#FIRST_LINE}
if [ $TITLE_LEN -gt 72 ]; then
    echo -e "${YELLOW}[commit-msg] WARNING: 提交标题过长 (${TITLE_LEN} 字符，建议 <= 72)${NC}"
fi

exit 0
