#!/bin/bash
# pre-commit: 代码质量检查 + 垃圾文件检测 + 敏感信息检测

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

ERRORS=0

echo -e "${YELLOW}[pre-commit] 运行检查...${NC}"

# === 1. 垃圾文件检测 ===
echo -e "\n${YELLOW}[1/3] 检查垃圾文件...${NC}"

JUNK_FILES=()

while IFS= read -r file; do
    case "$file" in
        *__pycache__/*|*.pyc|*.pyo|*.egg-info/*|.DS_Store|*.tmp|*.bak)
            JUNK_FILES+=("$file")
            ;;
    esac
done < <(git diff --cached --name-only --diff-filter=ACM)

if [ ${#JUNK_FILES[@]} -gt 0 ]; then
    echo -e "${RED}[ERROR] 检测到垃圾文件被暂存:${NC}"
    printf '  - %s\n' "${JUNK_FILES[@]}"
    echo -e "${YELLOW}请使用 'git reset HEAD <file>' 取消暂存，或删除这些文件${NC}"
    ERRORS=$((ERRORS + 1))
else
    echo -e "${GREEN}[OK] 未检测到垃圾文件${NC}"
fi

# === 2. 敏感信息检测 ===
echo -e "\n${YELLOW}[2/3] 检查敏感信息...${NC}"

SENSITIVE_PATTERNS=(
    'password\s*=\s*["\x27][^"\x27]+["\x27]'
    'api_key\s*=\s*["\x27][^"\x27]+["\x27]'
    'secret\s*=\s*["\x27][^"\x27]+["\x27]'
    'token\s*=\s*["\x27][^"\x27]+["\x27]'
    'sk-[a-zA-Z0-9]{20,}'
)

SENSITIVE_FOUND=0

for file in $(git diff --cached --name-only --diff-filter=ACM); do
    [ ! -f "$file" ] && continue
    case "$file" in
        *.png|*.jpg|*.jpeg|*.gif|*.ico|*.svg|*.woff|*.woff2|*.ttf|*.eot) continue ;;
    esac
    for pattern in "${SENSITIVE_PATTERNS[@]}"; do
        if grep -qiE "$pattern" "$file" 2>/dev/null; then
            echo -e "${RED}[WARNING] $file 可能包含敏感信息 (pattern: $pattern)${NC}"
            SENSITIVE_FOUND=1
        fi
    done
done

if [ $SENSITIVE_FOUND -eq 0 ]; then
    echo -e "${GREEN}[OK] 未检测到敏感信息${NC}"
fi

# === 3. ruff 检查（如果可用） ===
echo -e "\n${YELLOW}[3/3] ruff 检查...${NC}"

if command -v ruff &>/dev/null; then
    PY_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.py$' || true)
    if [ -n "$PY_FILES" ]; then
        if ! echo "$PY_FILES" | xargs ruff check 2>&1; then
            echo -e "${RED}[ERROR] ruff check 失败，请修复上述问题${NC}"
            ERRORS=$((ERRORS + 1))
        else
            echo -e "${GREEN}[OK] ruff check 通过${NC}"
        fi
    else
        echo -e "${GREEN}[OK] 无 Python 文件变更，跳过 ruff 检查${NC}"
    fi
else
    echo -e "${YELLOW}[SKIP] ruff 未安装，跳过代码检查${NC}"
fi

# === 结果 ===
echo ""
if [ $ERRORS -gt 0 ]; then
    echo -e "${RED}[pre-commit] 检查未通过 ($ERRORS 个错误)，提交被阻止${NC}"
    echo -e "${YELLOW}提示: 使用 'git commit --no-verify' 可跳过检查（不推荐）${NC}"
    exit 1
else
    echo -e "${GREEN}[pre-commit] 所有检查通过${NC}"
    exit 0
fi
