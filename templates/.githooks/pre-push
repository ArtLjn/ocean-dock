#!/bin/bash
# pre-push: 推送前运行测试（可选）

YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

if [ "$SKIP_PRE_PUSH_TESTS" = "1" ]; then
    echo -e "${YELLOW}[pre-push] 跳过推送前测试 (SKIP_PRE_PUSH_TESTS=1)${NC}"
    exit 0
fi

if ! command -v pytest &>/dev/null; then
    echo -e "${YELLOW}[pre-push] pytest 未安装，跳过测试${NC}"
    exit 0
fi

if [ ! -d "tests" ]; then
    echo -e "${YELLOW}[pre-push] 未找到 tests/ 目录，跳过测试${NC}"
    exit 0
fi

echo -e "${YELLOW}[pre-push] 运行测试...${NC}"

if pytest --tb=short -q 2>&1; then
    echo -e "${GREEN}[pre-push] 测试通过${NC}"
    exit 0
else
    echo -e "${YELLOW}[pre-push] 测试失败！${NC}"
    echo -e "${YELLOW}  推送已阻止。修复测试后重试，或使用以下命令跳过:${NC}"
    echo -e "${YELLOW}  SKIP_PRE_PUSH_TESTS=1 git push${NC}"
    exit 1
fi
